{
  "expo": {
    "name": "CleanCare",
    "slug": "cleancare",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cleancare",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B82F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uy.cleancare.app",
      "buildNumber": "8",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "CleanCare usa Bluetooth para activar las máquinas de lavado y secado",
        "NSBluetoothPeripheralUsageDescription": "CleanCare usa Bluetooth para activar las máquinas de lavado y secado",
        "NSLocationWhenInUseUsageDescription": "Algunas versiones de iOS requieren permiso de ubicación para escanear dispositivos Bluetooth cercanos",
        "UIBackgroundModes": ["bluetooth-central"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "package": "uy.cleancare.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ]
        }
      ],
      "expo-secure-store"
    ]
  }
}
