{
  "expo": {
    "name": "CleanCare",
    "slug": "cleancare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cleancare",
    "splash": {
      "backgroundColor": "#3B82F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uy.cleancare.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CleanCare necesita la cámara para escanear códigos QR de las máquinas"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3B82F6"
      },
      "package": "uy.cleancare.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-notifications",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ]
        }
      ],
      "expo-secure-store"
    ]
  }
}
